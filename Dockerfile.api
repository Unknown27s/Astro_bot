FROM python:3.11-slim as builder
WORKDIR /tmp
# Install build dependencies (minimal)
RUN apt-get update && apt-get install -y --no-install-recommends build-essential && rm -rf /var/lib/apt/lists/*
# Copy only requirements for layer caching
COPY requirements.txt .
# Pre-download wheels to /tmp/wheels (reproducible + faster)
RUN pip wheel --no-cache-dir --wheel-dir /wheels -r requirements.txt

FROM python:3.11-slim
WORKDIR /app
# Install runtime dependencies only (no build tools)
RUN apt-get update && apt-get install -y --no-install-recommends curl && rm -rf /var/lib/apt/lists/*
# Copy pre-built wheels from builder stage
COPY --from=builder /wheels /wheels
# Install wheels (fast, no compilation)
RUN pip install --no-index --find-links /wheels -r requirements.txt
# Copy application code LAST (most frequent changes)
COPY api_server.py config.py ./
COPY database/ ./database/
COPY ingestion/ ./ingestion/
COPY rag/ ./rag/
COPY auth/ ./auth/
COPY views/ ./views/
# Create data directories
RUN mkdir -p data/uploads data/chroma_db && chmod -R 755 data/
EXPOSE 8000
# Health check (provides docker readiness signal)
HEALTHCHECK --interval=30s --timeout=5s --retries=3 CMD curl -f http://localhost:8000/health || exit 1
# Default environment (overridable via docker-compose)
ENV PYTHONUNBUFFERED=1
ENV LLM_PROVIDER=groq
ENV EMBEDDING_MODEL=all-MiniLM-L6-v2
ENV CHROMA_HOST=chromadb
ENV CHROMA_PORT=8000
# Run FastAPI
CMD ["uvicorn", "api_server:app", "--host", "0.0.0.0", "--port", "8000"]
