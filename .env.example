# ── IMS AstroBot Environment Configuration ──
# ─────────────────────────────────────────
# DEVELOPER SETUP (Docker Compose)
# ─────────────────────────────────────────
# Use .env for docker-compose.yml (never commit .env)
# Copy this to .env and fill in values

# Cloud LLM (Dev: use Groq/Gemini; Prod: validate API keys)
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Database
DATABASE_URL=sqlite:///./data/astrobot.db
CHROMA_PERSIST_DIR=./data/chroma_db

# Debug & Logging
DEBUG=false
LOG_LEVEL=INFO

# ─────────────────────────────────────────
# PRODUCTION OVERRIDES
# ─────────────────────────────────────────
# Set on Docker host before: docker-compose -f docker-compose.prod.yml up -d
# GROQ_API_KEY=<prod-key>
# LLM_PROVIDER=groq
# DEBUG=false
# LOG_LEVEL=WARNING

# Path to GGUF model file (relative to project root or absolute)
MODEL_PATH=models\phi-3-mini-4k-instruct-q4.gguf

# Model parameters
MODEL_N_CTX=4096
MODEL_N_THREADS=4
MODEL_MAX_TOKENS=512
MODEL_TEMPERATURE=0.3

# ChromaDB
CHROMA_PERSIST_DIR=data/chroma_db

# Upload directory
UPLOAD_DIR=data/uploads

# SQLite database
SQLITE_DB_PATH=data/astrobot.db

# Admin default credentials (change after first login)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Embedding model
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Chunking parameters
CHUNK_SIZE=500
CHUNK_OVERLAP=50
